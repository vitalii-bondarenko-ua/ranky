generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum StepStatus {
  DRAFT
  ACTIVE
  CLOSED
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  votes        Vote[]
  projects     Project[]
  participants ProjectParticipant[]
  accounts     Account[]
  sessions     Session[]
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String?
  shareToken     String   @unique
  ownerId        String
  resultsPublic  Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner        User                 @relation(fields: [ownerId], references: [id])
  votingSteps  VotingStep[]
  participants ProjectParticipant[]
}

model VotingStep {
  id          String     @id @default(cuid())
  projectId   String
  title       String
  order       Int
  pointsRules Json
  status      StepStatus @default(DRAFT)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  votingItems VotingItem[]
  votes       Vote[]
}

model VotingItem {
  id          String   @id @default(cuid())
  stepId      String
  title       String
  description String?
  order       Int
  createdAt   DateTime @default(now())

  step VotingStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
}

model Vote {
  id        String   @id @default(cuid())
  userId    String
  stepId    String
  rankings  Json
  createdAt DateTime @default(now())

  user User       @relation(fields: [userId], references: [id])
  step VotingStep @relation(fields: [stepId], references: [id])

  @@unique([userId, stepId])
}

model ProjectParticipant {
  userId    String
  projectId String
  joinedAt  DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([userId, projectId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
